{"primaryContentSections":[{"content":[{"level":2,"text":"","type":"heading","anchor":""},{"inlineContent":[{"type":"text","text":"To assess the performance of BigInt, the execution times for a number of common operations were measured on an MacBook Pro 2024, Apple M3 chip."},{"type":"text","text":" "},{"type":"text","text":"The results are shown in the table below. It shows the operation being measured and the time it took (in microseconds or milliseconds)."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Four large numbers "},{"code":"a1000","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"b1000"},{"text":", ","type":"text"},{"type":"codeVoice","code":"c2000"},{"text":" and ","type":"text"},{"code":"p1000","type":"codeVoice"},{"text":" were used throughout the measurements. Their actual values are shown below the table.","type":"text"}]}],"name":"Note"},{"type":"table","alignments":["left","left","right"],"rows":[[[{"inlineContent":[{"type":"text","text":"Operation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Swift code"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Time"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"As string"}],"type":"paragraph"}],[{"inlineContent":[{"code":"c2000.asString()","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8.3 uSec","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"As signed bytes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"c2000.asSignedBytes()"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"0.18 uSec"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Bitwise and","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"a1000 & b1000"}],"type":"paragraph"}],[{"inlineContent":[{"text":"0.0