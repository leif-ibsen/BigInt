{"abstract":[{"text":"Signed fractions with numerator and denominator of unbounded size","type":"text"}],"sections":[],"seeAlsoSections":[{"title":"Articles","generated":true,"anchor":"Articles","identifiers":["doc:\/\/BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/BigInt\/documentation\/BigInt\/Algorithms","doc:\/\/BigInt\/documentation\/BigInt\/Performance","doc:\/\/BigInt\/documentation\/BigInt\/References"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Fractions are represented as ","type":"text"},{"identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","isActive":true,"type":"reference"},{"type":"text","text":" values consisting of a "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BInt","isActive":true},{"type":"text","text":" numerator value and a "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BInt","isActive":true},{"type":"text","text":" denominator value. The representation is normalized:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The numerator and denominator have no common factors except 1","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The denominator is always positive"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Zero is represented as 0\/1","type":"text"}],"type":"paragraph"}]}]},{"text":"Creating BFraction’s","type":"heading","level":3,"anchor":"Creating-BFractions"},{"type":"codeListing","code":["\/\/ From its numerator and denominator","let f = BFraction(17, 4)","","\/\/ From its decimal value","let f = BFraction(4.25)","","\/\/ From its string representation","let f = BFraction(\"4.25\")!","\/\/ or equivalently","let f = BFraction(\"425E-2\")!","","\/\/ From a continued fraction","let f = BFraction([3, 4, 12, 4])  \/\/ f = 649 \/ 200"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Defining a fraction by specifying its decimal value might lead to surprises,"},{"type":"text","text":" "},{"type":"text","text":"because not all decimal values can be represented exactly as a floating point number."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"One might think that "},{"type":"codeVoice","code":"BFraction(0.1)"},{"type":"text","text":" would equal 1\/10,"},{"type":"text","text":" "},{"type":"text","text":"but in fact it equals 3602879701896397 \/ 36028797018963968 = 0.1000000000000000055511151231257827021181583404541015625"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the other hand, "},{"type":"codeVoice","code":"BFraction(\"0.1\")!"},{"type":"text","text":" equals 1\/10."}]},{"text":"Converting BFraction’s","type":"heading","level":3,"anchor":"Converting-BFractions"},{"type":"paragraph","inlineContent":[{"text":"BFraction values can be converted to String values, to decimal String values, to Double values and to Continued Fraction values.","type":"text"}]},{"syntax":"swift","code":["let x = BFraction(1000, 7)","","\/\/ To String","let s1 = x.asString() \/\/ s1 = \"1000 \/ 7\"","","\/\/ To decimal String","let s1 = x.asDecimalString(precision: 8, exponential: false) \/\/ s1 = \"142.85714\"","let s2 = x.asDecimalString(precision: 8, exponential: true) \/\/ s2 = \"1.4285714E+2\"","","\/\/ To Double","let d = x.asDouble() \/\/ d = 142.8571428571429","","\/\/ To Continued Fraction","let f = x.asContinuedFraction() \/\/ f = [BInt(142), BInt(1), BInt(6)]"],"type":"codeListing"},{"level":3,"text":"Operations","type":"heading","anchor":"Operations"},{"inlineContent":[{"type":"text","text":"The operations available to "},{"identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","isActive":true,"type":"reference"},{"type":"text","text":" are:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Arithmetic:"}]},{"type":"text","text":" addition, subtraction, multiplication, division, exponentiation, modulus"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Comparison:"}],"type":"strong"},{"text":" The six standard operations ==  !=  <  <=  >  >=","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Rounding:","type":"text"}],"type":"strong"},{"type":"text","text":" Rounding fractions to integers"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Miscellaneous:"}],"type":"strong"},{"type":"text","text":" Bernoulli Numbers, Harmonic Numbers"}]}]}],"type":"unorderedList"},{"anchor":"Bernoulli-Numbers","level":3,"type":"heading","text":"Bernoulli Numbers"},{"type":"paragraph","inlineContent":[{"text":"The static function","type":"text"}]},{"code":["let Bn = BFraction.bernoulli(n)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"computes the n’th (n >= 0) Bernoulli number, which is a rational number.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example","type":"text"}]},{"code":["print(BFraction.bernoulli(60))","print(BFraction.bernoulli(60).asDecimalString(precision: 20, exponential: true))"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"would print","type":"text"}],"type":"paragraph"},{"code":["-1215233140483755572040304994079820246041491 \/ 56786730","-2.1399949257225333665E+34"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The static function"}],"type":"paragraph"},{"code":["let x = BFraction.bernoulliSequence(n)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n even numbered Bernoulli numbers B(0), B(2) … B(2 * n - 2)."}]},{"anchor":"Harmonic-Numbers","level":3,"text":"Harmonic Numbers","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let Hn = BFraction.harmonic(n)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"computes the n’th harmonic number, that is, 1 + 1\/2 + … + 1\/n"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"syntax":"swift","type":"codeListing","code":["let x = BFraction.harmonicSequence(n)"]},{"type":"paragraph","inlineContent":[{"text":"returns an array containing the first n harmonic numbers.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/BigInt\/documentation\/BigInt\/AboutBFraction","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/BigInt\/documentation\/BigInt"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","variants":[{"paths":["\/documentation\/bigint\/aboutbfraction"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"BigInt"}],"role":"article","title":"About BFraction"},"references":{"doc://BigInt/documentation/BigInt":{"abstract":[{"text":"Signed integers and fractions of unbounded size","type":"text"}],"identifier":"doc:\/\/BigInt\/documentation\/BigInt","type":"topic","url":"\/documentation\/bigint","role":"collection","kind":"symbol","title":"BigInt"},"doc://BigInt/documentation/BigInt/BFraction":{"abstract":[{"type":"text","text":"The BFraction structure"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"BFraction"}],"kind":"symbol","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","title":"BFraction","type":"topic","url":"\/documentation\/bigint\/bfraction","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"BFraction"}]},"doc://BigInt/documentation/BigInt/AboutBInt":{"url":"\/documentation\/bigint\/aboutbint","abstract":[{"text":"Signed integers of unbounded size","type":"text"}],"title":"About BInt",