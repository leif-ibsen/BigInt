{"metadata":{"title":"About BFraction","roleHeading":"Article","role":"article","modules":[{"name":"BigInt"}]},"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"identifiers":["doc:\/\/BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/BigInt\/documentation\/BigInt\/Algorithms","doc:\/\/BigInt\/documentation\/BigInt\/Performance","doc:\/\/BigInt\/documentation\/BigInt\/References"],"anchor":"Articles","generated":true,"title":"Articles"}],"hierarchy":{"paths":[["doc:\/\/BigInt\/documentation\/BigInt"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fractions are represented as "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","isActive":true},{"type":"text","text":" values consisting of a "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BInt","isActive":true},{"type":"text","text":" numerator value and a "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BInt","isActive":true},{"type":"text","text":" denominator value. The representation is normalized:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The numerator and denominator have no common factors except 1"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The denominator is always positive"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Zero is represented as 0\/1"}]}]}]},{"level":3,"text":"Creating BFraction’s","anchor":"Creating-BFractions","type":"heading"},{"code":["\/\/ From its numerator and denominator","let f = BFraction(17, 4)","","\/\/ From its decimal value","let f = BFraction(4.25)","","\/\/ From its string representation","let f = BFraction(\"4.25\")!","\/\/ or equivalently","let f = BFraction(\"425E-2\")!","","\/\/ From a continued fraction","let f = BFraction([3, 4, 12, 4])  \/\/ f = 649 \/ 200"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Defining a fraction by specifying its decimal value might lead to surprises,"},{"type":"text","text":" "},{"type":"text","text":"because not all decimal values can be represented exactly as a floating point number."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One might think that "},{"type":"codeVoice","code":"BFraction(0.1)"},{"type":"text","text":" would equal 1\/10,"},{"type":"text","text":" "},{"type":"text","text":"but in fact it equals 3602879701896397 \/ 36028797018963968 = 0.1000000000000000055511151231257827021181583404541015625"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On the other hand, "},{"type":"codeVoice","code":"BFraction(\"0.1\")!"},{"type":"text","text":" equals 1\/10."}],"type":"paragraph"},{"level":3,"type":"heading","text":"Converting BFraction’s","anchor":"Converting-BFractions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"BFraction values can be converted to String values, to decimal String values, to Double values and to Continued Fraction values."}]},{"code":["let x = BFraction(1000, 7)","","\/\/ To String","let s1 = x.asString() \/\/ s1 = \"1000 \/ 7\"","","\/\/ To decimal String","let s1 = x.asDecimalString(precision: 8, exponential: false) \/\/ s1 = \"142.85714\"","let s2 = x.asDecimalString(precision: 8, exponential: true) \/\/ s2 = \"1.4285714E+2\"","","\/\/ To Double","let d = x.asDouble() \/\/ d = 142.8571428571429","","\/\/ To Continued Fraction","let f = x.asContinuedFraction() \/\/ f = [BInt(142), BInt(1), BInt(6)]"],"syntax":"swift","type":"codeListing"},{"text":"Operations","type":"heading","anchor":"Operations","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The operations available to "},{"type":"reference","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","isActive":true},{"type":"text","text":" are:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Arithmetic:"}]},{"type":"text","text":" addition, subtraction, multiplication, division, exponentiation, modulus"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Comparison:"}]},{"type":"text","text":" The six standard operations ==  !=  <  <=  >  >="}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounding:"}]},{"type":"text","text":" Rounding fractions to integers"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Miscellaneous:"}]},{"type":"text","text":" Bernoulli Numbers, Harmonic Numbers"}],"type":"paragraph"}]}]},{"text":"Bernoulli Numbers","type":"heading","anchor":"Bernoulli-Numbers","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let Bn = BFraction.bernoulli(n)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n’th (n >= 0) Bernoulli number, which is a rational number."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example"}]},{"code":["print(BFraction.bernoulli(60))","print(BFraction.bernoulli(60).asDecimalString(precision: 20, exponential: true))"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"would print"}]},{"code":["-1215233140483755572040304994079820246041491 \/ 56786730","-2.1399949257225333665E+34"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let x = BFraction.bernoulliSequence(n)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n even numbered Bernoulli numbers B(0), B(2) … B(2 * n - 2)."}]},{"text":"Harmonic Numbers","type":"heading","anchor":"Harmonic-Numbers","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let Hn = BFraction.harmonic(n)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n’th harmonic number, that is, 1 + 1\/2 + … + 1\/n"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let x = BFraction.harmonicSequence(n)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"returns an array containing the first n harmonic numbers."}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/bigint\/aboutbfraction"]}],"abstract":[{"type":"text","text":"Signed fractions with numerator and denominator of unbounded size"}],"identifier":{"url":"doc:\/\/BigInt\/documentation\/BigInt\/AboutBFraction","interfaceLanguage":"swift"},"references":{"doc://BigInt/documentation/BigInt/References":{"kind":"article","role":"article","title":"References","abstract":[{"type":"text","text":"Algorithms from the following books and papers have been used in the implementation"}],"type":"topic","url":"\/documentation\/bigint\/references","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/References"},"doc://BigInt/documentation/BigInt/BFraction":{"type":"topic","url":"\/documentation\/bigint\/bfraction","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BFraction","title":"BFraction","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"BFraction"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BFraction","kind":"identifier"}],"abstract":[{"text":"The BFraction structure","type":"text"}]},"doc://BigInt/documentation/BigInt/AboutBInt":{"identifier":"doc:\/\/BigInt\/documentation\/BigInt\/AboutBInt","url":"\/documentation\/bigint\/aboutbint","title":"About BInt","abstract":[{"text":"Signed integers of unbounded size","type":"text"}],"type":"topic","role":"article","kind":"article"},"doc://BigInt/documentation/BigInt/Algorithms":{"kind":"article","url":"\/documentation\/bigint\/algorithms","title":"Algorithms","abstract":[{"text":"Some of the algorithms used in BigInt are described below","type":"text"}],"type":"topic","role":"article","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/Algorithms"},"doc://BigInt/documentation/BigInt/Performance":{"title":"Performance","kind":"article","abstract":[{"type":"text","text":"Execution times for certain BigInt operations"}],"role":"article","url":"\/documentation\/bigint\/performance","type":"topic","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/Performance"},"doc://BigInt/documentation/BigInt/AboutCRT":{"kind":"article","role":"article","title":"About CRT","type":"topic","abstract":[{"text":"Chinese Remainder Theorem","type":"text"}],"url":"\/documentation\/bigint\/aboutcrt","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/AboutCRT"},"doc://BigInt/documentation/BigInt/BInt":{"kind":"symbol","role":"symbol","title":"BInt","abstract":[{"type":"text","text":"The BInt structure"}],"type":"topic","url":"\/documentation\/bigint\/bint","identifier":"doc:\/\/BigInt\/documentation\/BigInt\/BInt","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BInt"}],"navigatorTitle":[{"text":"BInt","kind":"identifier"}]},"doc://BigInt/documentation/BigInt":{"type":"topic","role":"collection","abstract":[{"text":"Signed integers and fractions of unbounded size","type":"text"}],"url":"\/documentation\/bigint","identifier":"doc:\/\/BigInt\/documentation\/BigInt","kind":"symbol","title":"BigInt"}}}