{"seeAlsoSections":[{"identifiers":["doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutDivision","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Algorithms","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Performance","doc:\/\/bigint.BigInt\/documentation\/BigInt\/References"],"generated":true,"anchor":"Articles","title":"Articles"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/bigint\/aboutbfraction"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBFraction"},"abstract":[{"type":"text","text":"Signed fractions with numerator and denominator of unbounded size"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Fractions are represented as ","type":"text"},{"type":"reference","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BFraction","isActive":true},{"text":" values consisting of a ","type":"text"},{"type":"reference","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BInt","isActive":true},{"text":" numerator value and a ","type":"text"},{"identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BInt","type":"reference","isActive":true},{"text":" denominator value. The representation is normalized:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The numerator and denominator have no common factors except 1","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The denominator is always positive"}]}]},{"content":[{"inlineContent":[{"text":"Zero is represented as 0\/1","type":"text"}],"type":"paragraph"}]}]},{"level":3,"anchor":"Creating-BFractions","text":"Creating BFraction’s","type":"heading"},{"syntax":"swift","code":["\/\/ From its numerator and denominator","let f = BFraction(17, 4)","","\/\/ From its decimal value","let f = BFraction(4.25)","","\/\/ From its string representation","let f = BFraction(\"4.25\")!","\/\/ or equivalently","let f = BFraction(\"425E-2\")!","","\/\/ From a continued fraction","let f = BFraction([3, 4, 12, 4])  \/\/ f = 649 \/ 200"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Defining a fraction by specifying its decimal value might lead to surprises,"},{"type":"text","text":" "},{"type":"text","text":"because not all decimal values can be represented exactly as a floating point number."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One might think that "},{"type":"codeVoice","code":"BFraction(0.1)"},{"type":"text","text":" would equal 1\/10,"},{"type":"text","text":" "},{"type":"text","text":"but in fact it equals 3602879701896397 \/ 36028797018963968 = 0.1000000000000000055511151231257827021181583404541015625"}],"type":"paragraph"},{"inlineContent":[{"text":"On the other hand, ","type":"text"},{"code":"BFraction(\"0.1\")!","type":"codeVoice"},{"text":" equals 1\/10.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Converting-BFractions","text":"Converting BFraction’s","type":"heading"},{"inlineContent":[{"text":"BFraction values can be converted to String values, to decimal String values, to Double values and to Continued Fraction values.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let x = BFraction(1000, 7)","","\/\/ To String","let s1 = x.asString() \/\/ s1 = \"1000 \/ 7\"","","\/\/ To decimal String","let s1 = x.asDecimalString(precision: 8, exponential: false) \/\/ s1 = \"142.85714\"","let s2 = x.asDecimalString(precision: 8, exponential: true) \/\/ s2 = \"1.4285714E+2\"","","\/\/ To Double","let d = x.asDouble() \/\/ d = 142.8571428571429","","\/\/ To Continued Fraction","let f = x.asContinuedFraction() \/\/ f = [BInt(142), BInt(1), BInt(6)]"],"type":"codeListing"},{"level":3,"anchor":"Operations","text":"Operations","type":"heading"},{"inlineContent":[{"text":"The operations available to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BFraction"},{"text":" are:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Arithmetic:","type":"text"}]},{"type":"text","text":" addition, subtraction, multiplication, division, exponentiation, modulus"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Comparison:","type":"text"}]},{"type":"text","text":" The six standard operations ==  !=  <  <=  >  >="}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounding:"}]},{"text":" Rounding fractions to integers","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Miscellaneous:","type":"text"}]},{"text":" Bernoulli Numbers, Harmonic Numbers","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Bernoulli-Numbers","text":"Bernoulli Numbers","type":"heading"},{"inlineContent":[{"text":"The static function","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let Bn = BFraction.bernoulli(n)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n’th (n >= 0) Bernoulli number, which is a rational number."}]},{"type":"paragraph","inlineContent":[{"text":"For example","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(BFraction.bernoulli(60))","print(BFraction.bernoulli(60).asDecimalString(precision: 20, exponential: true))"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"would print"}]},{"type":"codeListing","syntax":"swift","code":["-1215233140483755572040304994079820246041491 \/ 56786730","-2.1399949257225333665E+34"]},{"type":"paragraph","inlineContent":[{"text":"The static function","type":"text"}]},{"type":"codeListing","code":["let x = BFraction.bernoulliSequence(n)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n even numbered Bernoulli numbers B(0), B(2) … B(2 * n - 2)."}]},{"level":3,"type":"heading","anchor":"Harmonic-Numbers","text":"Harmonic Numbers"},{"type":"paragraph","inlineContent":[{"text":"The static function","type":"text"}]},{"type":"codeListing","code":["let Hn = BFraction.harmonic(n)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n’th harmonic number, that is, 1 + 1\/2 + … + 1\/n"}]},{"type":"paragraph","inlineContent":[{"text":"The static function","type":"text"}]},{"code":["let x = BFraction.harmonicSequence(n)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"returns an array containing the first n harmonic numbers.","type":"text"}]}]}],"metadata":{"role":"article","modules":[{"name":"BigInt"}],"title":"About BFraction","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/bigint.BigInt\/documentation\/BigInt"]]},"references":{"doc://bigint.BigInt/documentation/BigInt/AboutDivision":{"title":"About Division","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutDivision","role":"article","kind":"article","type":"topic","abstract":[{"type":"text","text":"How rounding is done"}],"url":"\/documentation\/bigint\/aboutdivision"},"doc://bigint.BigInt/documentation/BigInt/AboutBInt":{"type":"topic","kind":"article","abstract":[{"type":"text","text":"Signed integers of unbounded size"}],"identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBInt","title":"About BInt","url":"\/documentation\/bigint\/aboutbint","role":"article"},"doc://bigint.BigInt/documentation/BigInt":{"abstract":[{"text":"Signed integers and fractions of unbounded size","type":"text"}],"kind":"symbol","url":"\/do