{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/bigint\/algorithms"]}],"abstract":[{"type":"text","text":"Some of the algorithms used in BigInt are described below"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"","type":"heading","anchor":""},{"type":"heading","anchor":"Multiplication","text":"Multiplication","level":3},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"ToomCook-3 algorithm for numbers with more than 16.000 bits"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Karatsuba algorithm for numbers with more than 9.600 bits","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Basecase - Knuth algorithm M","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Before release 1.24 the Schonhage-Strassen FFT based algorithm was used for very large numbers.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It turns out however, that the ToomCook-3 implementation is faster than"},{"text":" ","type":"text"},{"text":"the Schonhage-Strassen implementation, even for very large numbers.","type":"text"}]},{"text":"Division and Remainder","type":"heading","level":3,"anchor":"Division-and-Remainder"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Burnikel-Ziegler algorithm for divisors with more than 3.840 bits provided the dividend has at least 3.840 bits more than the divisor"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Basecase - Knuth algorithm D","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exact Division - Jebelean’s exact division algorithm"}]}]}]},{"text":"Greatest Common Divisor","level":3,"anchor":"Greatest-Common-Divisor","type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Recursive GCD algorithm 9.4.6 from [CRANDALL] for numbers with more than 128.000 bits","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Lehmer’s algorithm [KNUTH] chapter 4.5.2 for smaller numbers, with binary GCD basecase"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"text":"Extended Greatest Common Divisor","anchor":"Extended-Greatest-Common-Divisor"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Recursive GCD algorithm 9.4.6 from [CRANDALL] for numbers with more than 64.000 bits, with extra logic to track cofactors","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Lehmer’s algorithm [KNUTH] chapter 4.5.2 and exercise 18 for smaller numbers"}],"type":"paragraph"}]}]},{"type":"heading","text":"Modular Exponentiation","anchor":"Modular-Exponentiation","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sliding window algorithm 14.85 from [HANDBOOK] using Barrett reduction algorithm 14.42"}]},{"text":"Inverse Modulus","type":"heading","level":3,"anchor":"Inverse-Modulus"},{"type":"paragraph","inlineContent":[{"text":"If the modulus is a power of 2, it is computed using Newton iteration,","type":"text"},{"text":" ","type":"text"},{"text":"else it is computed via the extended GCD algorithm","type":"text"}]},{"text":"Square Root","type":"heading","level":3,"anchor":"Square-Root"},{"inlineContent":[{"type":"text","text":"Algorithm 1.12 (SqrtRem) from [BRENT] with algorithm 9.2.11 from [CRANDALL] as basecase"}],"type":"paragraph"},{"level":3,"anchor":"Square-Root-Modulo-a-Prime-Number","text":"Square Root Modulo a Prime Number","type":"heading"},{"inlineContent":[{"type":"text","text":"Algorithm 2.3.8 from [CRANDALL]"}],"type":"paragraph"},{"anchor":"Random-Numbers","type":"heading","text":"Random Numbers","level":3},{"type":"paragraph","inlineContent":[{"text":"Random ","type":"text"},{"type":"codeVoice","code":"BInt"},{"text":" numbers are generated using the cryptographically secure function ","type":"text"},{"code":"SecRandomCopyBytes","type":"codeVoice"}]},{"level":3,"anchor":"Prime-Number-Test","type":"heading","text":"Prime Number Test"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Baillie-PSW prime number test. Some facts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"It is a combination of a strong Fermat possible prime test to base 2, followed by a strong Lucas possible prime test"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"There is no known composite number that is declared ","type":"text"},{"code":"probablyPrime","type":"codeVoice"},{"text":" by the test","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It passes all prime number tests from Project Wycheproof"}]}]}],"type":"unorderedList"},{"type":"heading","level":3,"anchor":"Prime-Number-Generation","text":"Prime Number Generation"},{"type":"paragraph","inlineContent":[{"text":"The algorithm from Java BigInteger translated to Swift","type":"text"}]},{"type":"heading","text":"Factorial","anchor":"Factorial","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"SplitRecursive"},{"text":" algorithm from Peter Luschny: ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.luschny.de"}]},{"text":"Fibonacci","level":3,"type":"heading","anchor":"Fibonacci"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"fastDoubling","type":"codeVoice"},{"text":" algorithm from Project Nayuki: ","type":"text"},{"identifier":"https:\/\/www.nayuki.io","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Jacobi and Kronecker symbols","level":3,"type":"heading","anchor":"Jacobi-and-Kronecker-symbols"},{"inlineContent":[{"text":"Algorithm 2.3.5 from [CRANDALL]","type":"text"}],"type":"paragraph"},{"text":"Bernoulli Numbers","level":3,"type":"heading","anchor":"Bernoulli-Numbers"},{"type":"paragraph","inlineContent":[{"text":"Computed via Tangent numbers which is fast because it only involves integer arithmetic","type":"text"},{"text":" ","type":"text"},{"text":"but no fraction arithmetic","type":"text"}]},{"anchor":"Chinese-Remainder-Theorem","text":"Chinese Remainder Theorem","type":"heading","level":3},{"inlineContent":[{"text":"The Garner algorithm 2.1.7 from [CRANDALL]","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","identifier":{"url":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/Algorithms","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/bigint.BigInt\/documentation\/BigInt"]]},"metadata":{"title":"Algorithms","role":"article","modules":[{"name":"BigInt"}],"roleHeading":"Article"},"seeAlsoSections":[{"identifiers":["doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBFraction","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutDivision","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Performance","doc:\/\/bigint.BigInt\/documentation\/BigInt\/References"],"generated":true,"title":"Articles","anchor":"Articles"}],"sections":[],"references":{"doc://bigint.BigInt/documentation/BigInt/AboutDivision":{"title":"About Division","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutDivision","role":"article","kind":"article","type":"topic","abstract":[{"type":"text","text":"How rounding is done"}],"url":"\/documentation\/bigint\/aboutdivision"},"doc://bigint.BigInt/documentation/BigInt/Performance":{"identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/Performance","url":"\/documentation\/bigint\/performance","kind":"article","title":"Performance","abstract":[{"text":"Execution times for certain BigInt operations","type":"text"}],"role":"article","type":"topic"},"doc://bigint.BigInt/documentation/BigInt":{"abstract":[{"text":"Signed integers and fract