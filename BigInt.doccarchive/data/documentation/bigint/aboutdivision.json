{"seeAlsoSections":[{"identifiers":["doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBFraction","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Algorithms","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Performance","doc:\/\/bigint.BigInt\/documentation\/BigInt\/References"],"anchor":"Articles","title":"Articles","generated":true}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","variants":[{"paths":["\/documentation\/bigint\/aboutdivision"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutDivision"},"abstract":[{"text":"How rounding is done","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"","type":"heading","text":"","level":2},{"inlineContent":[{"text":"If an integer ","type":"text"},{"type":"codeVoice","code":"x"},{"type":"text","text":" divided by "},{"code":"d","type":"codeVoice"},{"type":"text","text":" gives quotient "},{"code":"q","type":"codeVoice"},{"type":"text","text":" and remainder "},{"code":"r","type":"codeVoice"},{"type":"text","text":", then it is true that"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"x = d * q + r","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"|r| < |d|"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For given x and d, if the remainder is not zero, there will be two possible (q, r) pairs. For example:"}]},{"inlineContent":[{"type":"text","text":"11 \/ 4 = (2, 3) and 11 \/ 4 = (3, -1)"}],"type":"paragraph"},{"inlineContent":[{"text":"and","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"-11 \/ 4 = (-2, -3) and -11 \/ 4 = (-3, 1)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"t